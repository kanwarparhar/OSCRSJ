# Resend (transactional email - https://resend.com/api-keys)
RESEND_API_KEY=
# Set after creating the webhook in the Resend dashboard
RESEND_WEBHOOK_SECRET=
EMAIL_FROM="OSCRSJ Editorial Office <noreply@oscrsj.com>"

# JWT secret for co-author dispute tokens (32-byte hex; generate via `openssl rand -hex 32`)
DISPUTE_TOKEN_SECRET=
